<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/moderate_bg"
    android:gravity="center">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Warning icon (animated pulse) -->
            <ImageView
                android:id="@+id/ivWarningIcon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_warning"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DROWSINESS DETECTED"
                android:textColor="@color/moderate_accent"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Message -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You are feeling drowsy.\nPlease stay alert!"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="28dp" />

            <!-- Suggestion card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/moderate_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡  Take a short break or refresh with coffee"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:padding="20dp"
                    android:lineSpacingExtra="4dp" />
            </androidx.cardview.widget.CardView>

            <!-- Open Maps button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenCoffee"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="☕   Find Coffee Nearby"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_accent"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@color/moderate_accent"
                app:cornerRadius="14dp" />

            <!-- Play music button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayMusic"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="🎵   Play Alert Music"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@color/moderate_surface"
                app:strokeColor="@color/moderate_accent"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp" />

            <!-- Dismiss button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDismissModerate"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="✅   I'm Alert Now"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp"
                app:backgroundTint="@color/surface_elevated"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
